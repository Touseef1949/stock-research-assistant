# Stock Research Assistant — Secrets Configuration
# 
# Copy this file to .streamlit/secrets.toml and fill in real values.
# NEVER commit the real secrets.toml — it is gitignored.

# === AI / LLM ===
# DeepSeek API key for the 5-agent analysis pipeline
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY = "sk-your-deepseek-api-key-here"

# === Supabase (Auth + User Management) ===
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_KEY = "your-anon-public-key"
SUPABASE_SERVICE_KEY = "your-service-role-key-keep-secret"

# === Razorpay (Payments — Pro tier ₹199/month) ===
# Get from: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID = "rzp_live_your-key-id"
RAZORPAY_KEY_SECRET = "your-key-secret"

# === Optional: Kite Connect (Live NSE prices — not for SaaS use) ===
# Only needed if running locally with Kite data feed.
# KITE_API_KEY = "your-kite-api-key"
# KITE_ACCESS_TOKEN = "your-kite-access-token"
